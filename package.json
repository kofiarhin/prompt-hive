{
  "name": "prompt-hive",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles",
    "test:client": "npm run test --prefix client",
    "client": "npm run dev --prefix client",
    "server": "nodemon server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node server/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "nodemon": "^3.1.14",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/server/__tests__/**/*.test.js"],
    "globalSetup": "./server/__tests__/globalSetup.js",
    "globalTeardown": "./server/__tests__/globalTeardown.js"
  }
}
